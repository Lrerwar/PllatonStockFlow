rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Config (whitelist de e-mails) — qualquer logado lê, só admin escreve
    // Na prática: qualquer logado pode ler para verificar whitelist
    match /compartilhado/config {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Dados compartilhados (produtos, vendas, snapshots)
    match /compartilhado/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
